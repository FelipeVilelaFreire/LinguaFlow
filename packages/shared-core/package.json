{
  "name": "@linguaflow/shared-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks/adventure": {
      "types": "./dist/hooks/adventure/index.d.ts",
      "import": "./dist/hooks/adventure/index.js",
      "require": "./dist/hooks/adventure/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/hooks/adventure/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/hooks/adventure/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "tsup": "^8.3.5",
    "typescript": "^5.4.5"
  }
}
